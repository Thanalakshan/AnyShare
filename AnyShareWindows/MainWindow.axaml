<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="AnyShareWindows.MainWindow"
        Width="380"
        Height="430"
        Title="AnyShare"
        Icon="/Assets/icon/icon.ico"
        Background="#0A0A0C"
        ShowInTaskbar="False"
        WindowState="Minimized"
        CanResize="False">

    <ScrollViewer>
        <StackPanel Margin="20" Spacing="12">

            <TextBlock Text="AnyShare"
                       FontSize="32"
                       FontWeight="Bold"
                       Foreground="White"
                       Margin="0,0,0,8"/>

            <Button x:Name="SpeedCard" Classes="toggleCard">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Text="Network Speed Monitor"
                               Foreground="White"
                               FontWeight="Bold"
                               FontSize="15"
                               VerticalAlignment="Center"/>
                    <ToggleSwitch x:Name="SpeedToggle"
                                  Grid.Column="1"
                                  IsHitTestVisible="False"/>
                </Grid>
            </Button>

            <StackPanel x:Name="SpeedDetailsPanel" IsVisible="False" Spacing="12">

                <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                    <Border Grid.Column="0" Classes="card">
                        <StackPanel Spacing="8" HorizontalAlignment="Center">
                            <TextBlock Text="Download"
                                       Foreground="#6B7280"
                                       FontSize="11"
                                       TextAlignment="Center"/>
                            <TextBlock x:Name="DownloadSpeedText"
                                       Text="0 KB/s"
                                       Foreground="#3A86FF"
                                       FontWeight="Bold"
                                       FontSize="18"
                                       TextAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Classes="card">
                        <StackPanel Spacing="8" HorizontalAlignment="Center">
                            <TextBlock Text="Upload"
                                       Foreground="#6B7280"
                                       FontSize="11"
                                       TextAlignment="Center"/>
                            <TextBlock x:Name="UploadSpeedText"
                                       Text="0 KB/s"
                                       Foreground="#3A86FF"
                                       FontWeight="Bold"
                                       FontSize="18"
                                       TextAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <Border Classes="card">
                    <StackPanel Spacing="10">

                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Text="Today Usage"
                                       Foreground="White"
                                       FontSize="14"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center"/>

                            <Button x:Name="ResetButton"
                                    Grid.Column="1"
                                    Classes="resetBtn"
                                    Content="Reset"/>
                        </Grid>

                        <Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto,Auto">
                            <TextBlock Grid.Row="0" Grid.Column="0"
                                       Text="Download"
                                       Foreground="#6B7280"
                                       FontSize="11"
                                       HorizontalAlignment="Center"/>

                            <TextBlock Grid.Row="0" Grid.Column="1"
                                       Text="Upload"
                                       Foreground="#6B7280"
                                       FontSize="11"
                                       HorizontalAlignment="Center"/>

                            <TextBlock Grid.Row="0" Grid.Column="2"
                                       Text="Total"
                                       Foreground="#6B7280"
                                       FontSize="11"
                                       HorizontalAlignment="Center"/>

                            <TextBlock x:Name="DownloadUsageText"
                                       Grid.Row="1" Grid.Column="0"
                                       Text="0 MB"
                                       Foreground="White"
                                       FontSize="14"
                                       HorizontalAlignment="Center"/>

                            <TextBlock x:Name="UploadUsageText"
                                       Grid.Row="1" Grid.Column="1"
                                       Text="0 MB"
                                       Foreground="White"
                                       FontSize="14"
                                       HorizontalAlignment="Center"/>

                            <TextBlock x:Name="TodayUsageText"
                                       Grid.Row="1" Grid.Column="2"
                                       Text="0 MB"
                                       Foreground="White"
                                       FontSize="14"
                                       HorizontalAlignment="Center"/>
                        </Grid>

                        <TextBlock x:Name="NetworkSourceText"
                                   Text="Unknown"
                                   Foreground="#6B7280"
                                   FontSize="12"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Button x:Name="HistoryToggleButton" Classes="toggleCard" Padding="16,10">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Text="7-Day History"
                                   Foreground="White"
                                   FontWeight="Bold"
                                   FontSize="14"
                                   VerticalAlignment="Center"/>
                        <TextBlock x:Name="HistoryArrow"
                                   Text="▼"
                                   Foreground="#6B7280"
                                   Grid.Column="1"
                                   FontSize="12"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Button>

                <Border x:Name="HistoryPanel" IsVisible="False" Classes="card">
                    <StackPanel x:Name="HistoryItemsPanel" Spacing="6"/>
                </Border>
            </StackPanel>

            <Button x:Name="SharingCard" Classes="toggleCard">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Text="Network Sharing"
                               Foreground="White"
                               FontWeight="Bold"
                               FontSize="15"
                               VerticalAlignment="Center"/>
                    <ToggleSwitch x:Name="SharingToggle"
                                  Grid.Column="1"
                                  IsHitTestVisible="False"/>
                </Grid>
            </Button>

            <Button x:Name="ClipboardCard" Classes="toggleCard">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Text="Clipboard Sharing"
                               Foreground="White"
                               FontWeight="Bold"
                               FontSize="15"
                               VerticalAlignment="Center"/>
                    <ToggleSwitch x:Name="ClipboardToggle"
                                  Grid.Column="1"
                                  IsHitTestVisible="False"/>
                </Grid>
            </Button>

            <StackPanel x:Name="ClipboardActionsPanel"
                        IsVisible="False"
                        Spacing="8"
                        HorizontalAlignment="Stretch">
                        

                <Button x:Name="SendClipboardButton"
                        Classes="primaryAction"
                        Content="Send Clipboard to Android"/>

                <Button x:Name="ReceiveClipboardButton"
                        Classes="primaryAction"
                        Content="Receive Clipboard from Android"/>
                            </StackPanel>

            <Button x:Name="StartupCard" Classes="toggleCard">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Text="Open at Startup"
                               Foreground="White"
                               FontWeight="Bold"
                               FontSize="15"
                               VerticalAlignment="Center"/>
                    <ToggleSwitch x:Name="StartupToggle"
                                  Grid.Column="1"
                                  IsHitTestVisible="False"/>
                </Grid>
            </Button>

        </StackPanel>
    </ScrollViewer>
</Window>