<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="AnyShareWindows.MainWindow"
        Width="380"
        Height="600"
        Title="AnyShare"
        Background="#0A0A0C"
        ShowInTaskbar="False"
        WindowState="Minimized"
        CanResize="False">

    <ScrollViewer>
        <StackPanel Margin="20" Spacing="12">

            <TextBlock Text="AnyShare"
                       FontSize="32"
                       FontWeight="Bold"
                       Foreground="White"
                       Margin="0,0,0,8"/>

            <!-- Speed Monitor Card -->
            <Button x:Name="SpeedCard" Classes="toggleCard">
                <StackPanel Spacing="0">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Text="Network Speed Monitor" 
                                   Foreground="White" 
                                   FontWeight="Bold"
                                   FontSize="15"
                                   VerticalAlignment="Center"/>
                        <ToggleSwitch x:Name="SpeedToggle" 
                                      Grid.Column="1"
                                      IsHitTestVisible="False"/>
                    </Grid>
                </StackPanel>
            </Button>

            <!-- Speed Details - Only visible when enabled -->
            <StackPanel x:Name="SpeedDetailsPanel" IsVisible="False" Spacing="12">
                <!-- Live Speeds Cards - Side by Side -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                    <!-- Download Speed Card -->
                    <Border Grid.Column="0" Classes="card">
                        <StackPanel Spacing="8" HorizontalAlignment="Center">
                            <TextBlock Text="Download" 
                                       Foreground="#6B7280" 
                                       FontSize="11"
                                       TextAlignment="Center"/>
                            <TextBlock x:Name="DownloadSpeedText" 
                                       Text="0 KB/s" 
                                       Foreground="#3A86FF"
                                       FontWeight="Bold" 
                                       FontSize="18"
                                       TextAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- Upload Speed Card -->
                    <Border Grid.Column="1" Classes="card">
                        <StackPanel Spacing="8" HorizontalAlignment="Center">
                            <TextBlock Text="Upload" 
                                       Foreground="#6B7280" 
                                       FontSize="11"
                                       TextAlignment="Center"/>
                            <TextBlock x:Name="UploadSpeedText" 
                                       Text="0 KB/s" 
                                       Foreground="#3A86FF"
                                       FontWeight="Bold" 
                                       FontSize="18"
                                       TextAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Today Stats -->
                <Border Classes="card">
                    <StackPanel Spacing="6">
                        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto">
                            <TextBlock Text="Today Usage" 
                                       Foreground="White" 
                                       FontWeight="Bold"
                                       FontSize="14"/>
                            <Button x:Name="ResetButton" 
                                    Grid.Column="1"
                                    Classes="resetBtn"
                                    Content="Reset"
                                    Padding="8,4"
                                    FontSize="11"/>
                            
                            <TextBlock Text="Total:" Foreground="#6B7280" FontSize="12" Grid.Row="1"/>
                            <TextBlock x:Name="TodayUsageText" Text="0 MB" 
                                       Foreground="White" Grid.Column="1" Grid.Row="1" FontWeight="Bold" FontSize="12"/>
                            
                            <TextBlock Text="Source:" Foreground="#6B7280" FontSize="12" Grid.Row="2"/>
                            <TextBlock x:Name="NetworkSourceText" Text="Unknown" 
                                       Foreground="#3A86FF" Grid.Column="1" Grid.Row="2" FontWeight="Bold" FontSize="12"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 7-Day History -->
                <Button x:Name="HistoryToggleButton" Classes="toggleCard" Padding="16,10">
                    <StackPanel Spacing="0">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Text="7-Day History" 
                                       Foreground="White" 
                                       FontWeight="Bold"
                                       FontSize="14"
                                       VerticalAlignment="Center"/>
                            <TextBlock x:Name="HistoryArrow" Text="▼" 
                                       Foreground="#6B7280" Grid.Column="1" FontSize="12" VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </Button>

                <!-- History Details -->
                <Border x:Name="HistoryPanel" IsVisible="False" Classes="card">
                    <StackPanel x:Name="HistoryItemsPanel" Spacing="6">
                        <!-- Items will be added dynamically -->
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Network Sharing Card -->
            <Button x:Name="SharingCard" Classes="toggleCard">
                <StackPanel Spacing="0">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Text="Network Sharing" 
                                   Foreground="White" 
                                   FontWeight="Bold"
                                   FontSize="15"
                                   VerticalAlignment="Center"/>
                        <ToggleSwitch x:Name="SharingToggle" 
                                      Grid.Column="1"
                                      IsHitTestVisible="False"/>
                    </Grid>
                </StackPanel>
            </Button>

            <!-- Clipboard Sharing Card -->
            <Button x:Name="ClipboardCard" Classes="toggleCard">
                <StackPanel Spacing="0">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Text="Clipboard Sharing" 
                                   Foreground="White" 
                                   FontWeight="Bold"
                                   FontSize="15"
                                   VerticalAlignment="Center"/>
                        <ToggleSwitch x:Name="ClipboardToggle" 
                                      Grid.Column="1"
                                      IsHitTestVisible="False"/>
                    </Grid>
                </StackPanel>
            </Button>

            <!-- Open at Startup Card -->
            <Button x:Name="StartupCard" Classes="toggleCard">
                <StackPanel Spacing="0">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Text="Open at Startup" 
                                   Foreground="White" 
                                   FontWeight="Bold"
                                   FontSize="15"
                                   VerticalAlignment="Center"/>
                        <ToggleSwitch x:Name="StartupToggle" 
                                      Grid.Column="1"
                                      IsHitTestVisible="False"/>
                    </Grid>
                </StackPanel>
            </Button>

        </StackPanel>
    </ScrollViewer>
</Window>