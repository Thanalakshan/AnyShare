<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AnyShareWindows.App"
             RequestedThemeVariant="Dark">

    <Application.Styles>
        <FluentTheme />

        <Style Selector="Border.card">
            <Setter Property="Background" Value="#111115"/>
            <Setter Property="BorderBrush" Value="#1E1E24"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="16"/>
        </Style>
    </Application.Styles>

    <TrayIcon.Icons>
        <TrayIcons>
            <TrayIcon Icon="/Assets/avalonia-logo.ico"
                      ToolTipText="AnyShare">
                <TrayIcon.Menu>
                    <NativeMenu>
                        <NativeMenuItem Header="Open AnyShare"
                                        Command="{ReflectionBinding OpenCommand}" />
                        <NativeMenuItemSeparator />
                        <NativeMenuItem Header="Exit"
                                        Command="{ReflectionBinding ExitCommand}" />
                    </NativeMenu>
                </TrayIcon.Menu>
            </TrayIcon>
        </TrayIcons>
    </TrayIcon.Icons>
</Application>