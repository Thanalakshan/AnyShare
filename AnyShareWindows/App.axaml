<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AnyShareWindows.App"
             RequestedThemeVariant="Dark">

    <Application.Styles>
        <FluentTheme />

        <Style Selector="Button.primaryAction">
            <Setter Property="Background" Value="#3A86FF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#3A86FF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>

        <Style Selector="Button.primaryAction /template/ ContentPresenter">
            <Setter Property="Background" Value="#3A86FF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#3A86FF"/>
        </Style>

        <Style Selector="Button.primaryAction:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#3A86FF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#3A86FF"/>
        </Style>

        <Style Selector="Button.primaryAction:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="#3A86FF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#3A86FF"/>
        </Style>

        <Style Selector="Border.card">
            <Setter Property="Background" Value="#111115"/>
            <Setter Property="BorderBrush" Value="#1E1E24"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="16"/>
        </Style>

        <Style Selector="Button.toggleCard">
            <Setter Property="Background" Value="#111115"/>
            <Setter Property="BorderBrush" Value="#1E1E24"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="Margin" Value="0,0,0,0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style Selector="Button.toggleCard:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#1A1A1F"/>
        </Style>

        <Style Selector="Button.resetBtn">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#3A86FF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#3A86FF"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
        </Style>

        <Style Selector="Button.resetBtn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#3A86FF"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </Application.Styles>
</Application>